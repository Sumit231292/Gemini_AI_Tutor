# ============================================================
# GeminiTutor - Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# ── Google AI / Gemini ──
# Option A: Use a Google AI Studio API key (simplest for development)
GOOGLE_API_KEY=AIzaSyCcGFw5lknZvAZv_HbwnLMpInXQnup_-Yc

# Option B: Use Vertex AI (for production / Cloud Run)
# Comment out GOOGLE_API_KEY above and set these instead:
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# GOOGLE_CLOUD_REGION=us-central1

# ── Google Cloud Firestore (user storage) ──
# Set your GCP project ID to enable Firestore for persistent user data.
# Also run: gcloud auth application-default login
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# ── Model Configuration ──
# GEMINI_MODEL=gemini-2.5-flash-native-audio-latest
# GEMINI_VISION_MODEL=gemini-2.5-flash

# ── Server Settings ──
# HOST=0.0.0.0
# PORT=8000
# DEBUG=false
